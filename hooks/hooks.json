{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-/nonexistent}/adapters/claude-code/hook_dispatch.sh\" session-start",
            "timeout": 30,
            "statusMessage": "Loading FMC continuity"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-/nonexistent}/adapters/claude-code/hook_dispatch.sh\" user-prompt-submit",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-/nonexistent}/adapters/claude-code/hook_dispatch.sh\" session-end",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-/nonexistent}/adapters/claude-code/hook_dispatch.sh\" pre-compact",
            "timeout": 5,
            "statusMessage": "Preserving FMC continuity"
          }
        ]
      }
    ]
  }
}
