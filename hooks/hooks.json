{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s\\n' 'FMC active (farky-memory-container)' 'Silent work is good. Silent fallback is forbidden.' 'If `./memory/MEMORY.md` exists, read it.'"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT:-/nonexistent}/scripts/capability_report.sh\" --startup --plugin-dir \"${CLAUDE_PLUGIN_ROOT:-.}\" --project-dir \"${CLAUDE_PROJECT_DIR:-.}\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
